[Unit]
Description=KnockBlock status sign
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@WORKDIR@
ExecStart=@WORKDIR@/venv/bin/python3 @WORKDIR@/app.py
Restart=on-failure

# Root because the LED matrix library needs raw GPIO access; the library's
# own privilege drop is disabled in matrix.py so the venv stays readable.
User=root

[Install]
WantedBy=multi-user.target
